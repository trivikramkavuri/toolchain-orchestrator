{
  "name": "toolchain-orchestrator",
  "version": "0.1.0",
  "description": "CLI-based pipeline orchestrator for common dev workflows (lint, test, build, deploy-preview).",
  "main": "lib/cli/index.js",
  "types": "lib/cli/index.d.ts",
  "bin": {
    "toolchain": "./lib/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src",
    "format": "prettier --write src"
  },
  "keywords": [
    "cli",
    "pipeline",
    "workflow",
    "orchestrator",
    "dev-tools"
  ],
  "author": "trivikramkavuri",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}
